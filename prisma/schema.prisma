// ============================================
// ORDER ASSIGNMENT (Sales → Manager → Sewer)
// ============================================

enum AssignmentMethod {
  manual
  automatic
}

enum AssignmentStatus {
  pending      // waiting for sewer response
  accepted     // sewer accepted
  rejected     // sewer rejected (re-assign)
  in_progress  // sewer started
  completed    // sewer finished
}

model OrderAssignment {
  id              Int              @id @default(autoincrement())
  orderId         Int              @unique @map("order_id")
  sewerId         Int              @map("sewer_id")
  assignedById    Int?             @map("assigned_by_id")
  method          AssignmentMethod @default(manual)
  status          AssignmentStatus @default(pending)

  // Sewer response
  responseAt      DateTime?        @map("response_at")
  rejectReason    String?          @map("reject_reason") @db.Text

  // Measurements provided for this order (merged from customer + sewer input)
  // JSON shape: { waist, chest, hips, height, shoulderWidth, sleeveLength,
  //               neckCircumference, backLength, frontLength, hipLength,
  //               clothType: "habesha"|"chiffon"|"other",
  //               notes, predictedSizes }
  measurements    Json?            @db.Json

  // Fabric requirement (meters) computed by the system
  fabricMetersRequired Decimal?   @map("fabric_meters_required") @db.Decimal(8, 2)

  // Sewing notes / progress update
  sewerNotes      String?          @map("sewer_notes") @db.Text
  startedAt       DateTime?        @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  estimatedDoneAt DateTime?        @map("estimated_done_at")

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sewer           User             @relation("AssignedSewer", fields: [sewerId], references: [id])
  assignedBy      User?            @relation("AssignedByManager", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([sewerId])
  @@index([status])
  @@index([method])
  @@map("order_assignments")
}

// ============================================
// RAW MATERIAL (Cloth Stock)
// ============================================

enum ClothType {
  habesha_cotton
  chiffon
  silk
  satin
  linen
  polyester
  velvet
  organza
  other
}

model RawMaterial {
  id              Int        @id @default(autoincrement())
  name            String     @db.VarChar(200)
  clothType       ClothType  @map("cloth_type") @default(other)
  colorOrPattern  String?    @map("color_or_pattern") @db.VarChar(200)
  supplier        String?    @db.VarChar(200)
  unitOfMeasure   String     @default("meters") @map("unit_of_measure") @db.VarChar(20)

  // Stock
  quantityInStock Decimal    @default(0) @map("quantity_in_stock") @db.Decimal(10, 2)
  lowStockAlert   Decimal    @default(5) @map("low_stock_alert") @db.Decimal(10, 2)

  // Cost
  costPerMeter    Decimal    @default(0) @map("cost_per_meter") @db.Decimal(10, 2)
  currency        String     @default("ETB") @db.VarChar(3)

  // Fabric width (cm) — needed for cut calculation
  widthCm         Decimal?   @map("width_cm") @db.Decimal(6, 2)

  notes           String?    @db.Text
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  fabricCuts      FabricCut[]
  stockMovements  StockMovement[]

  @@index([clothType])
  @@index([isActive])
  @@map("raw_materials")
}

// ============================================
// FABRIC CUT (per order — meters deducted)
// ============================================

model FabricCut {
  id              Int         @id @default(autoincrement())
  orderId         Int         @map("order_id")
  rawMaterialId   Int         @map("raw_material_id")

  // Calculated cut requirements
  // For habesha: typical full dress = 5–7 m; top = 2–3 m; skirt = 3–4 m
  // Formula stored for transparency
  clothType       ClothType   @map("cloth_type")
  garmentType     String      @map("garment_type") @db.VarChar(100)  // "full_dress", "top", "skirt", etc.
  metersRequired  Decimal     @map("meters_required") @db.Decimal(8, 2)
  metersActualCut Decimal?    @map("meters_actual_cut") @db.Decimal(8, 2)
  wastePercent    Decimal     @default(10) @map("waste_percent") @db.Decimal(5, 2)

  // Who cut and when
  cutById         Int?        @map("cut_by_id")
  cutAt           DateTime?   @map("cut_at")
  notes           String?     @db.Text

  createdAt       DateTime    @default(now()) @map("created_at")

  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rawMaterial     RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@index([orderId])
  @@index([rawMaterialId])
  @@map("fabric_cuts")
}

// ============================================
// STOCK MOVEMENT (Income / Expense Ledger)
// ============================================

enum StockMovementType {
  purchase        // incoming stock (expense: money out, cloth in)
  fabric_cut      // cloth cut for order (stock deduction)
  return          // supplier return (credit)
  adjustment      // manual stock correction
  waste           // waste/damage write-off
}

enum StockMovementDirection {
  in   // stock increases
  out  // stock decreases
}

model StockMovement {
  id              Int                    @id @default(autoincrement())
  rawMaterialId   Int                    @map("raw_material_id")
  type            StockMovementType
  direction       StockMovementDirection
  quantityChange  Decimal                @map("quantity_change") @db.Decimal(10, 2)
  quantityBefore  Decimal                @map("quantity_before") @db.Decimal(10, 2)
  quantityAfter   Decimal                @map("quantity_after") @db.Decimal(10, 2)

  // Financial
  unitCost        Decimal?               @map("unit_cost") @db.Decimal(10, 2)
  totalCost       Decimal?               @map("total_cost") @db.Decimal(15, 2)
  currency        String                 @default("ETB") @db.VarChar(3)

  // Reference
  referenceOrderId Int?                  @map("reference_order_id")
  supplier        String?                @db.VarChar(200)
  invoiceNumber   String?                @map("invoice_number") @db.VarChar(100)
  note            String?                @db.Text

  createdById     Int?                   @map("created_by_id")
  createdAt       DateTime               @default(now()) @map("created_at")

  rawMaterial     RawMaterial @relation(fields: [rawMaterialId], references: [id])
  createdBy       User?       @relation("StockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([rawMaterialId])
  @@index([type])
  @@index([direction])
  @@index([createdAt])
  @@map("stock_movements")
}

// ============================================
// PAYROLL SYSTEM
// ============================================

enum PayrollStatus {
  draft
  pending_approval
  approved
  paid
  rejected
}

enum PayPeriodType {
  monthly
  biweekly
  weekly
}

model Payroll {
  id              Int            @id @default(autoincrement())
  userId          Int            @map("user_id")
  
  // Pay period
  periodType      PayPeriodType  @default(monthly) @map("period_type")
  periodStart     DateTime       @map("period_start")
  periodEnd       DateTime       @map("period_end")
  
  // Earnings
  baseSalary      Decimal        @map("base_salary") @db.Decimal(12, 2)
  overtimePay     Decimal        @default(0) @map("overtime_pay") @db.Decimal(12, 2)
  bonus           Decimal        @default(0) @db.Decimal(12, 2)
  commission      Decimal        @default(0) @db.Decimal(12, 2)
  allowances      Decimal        @default(0) @db.Decimal(12, 2)
  
  // Deductions
  taxDeduction    Decimal        @default(0) @map("tax_deduction") @db.Decimal(12, 2)
  pensionDeduction Decimal       @default(0) @map("pension_deduction") @db.Decimal(12, 2)
  otherDeductions Decimal        @default(0) @map("other_deductions") @db.Decimal(12, 2)
  deductionNotes  String?        @map("deduction_notes") @db.Text
  
  // Computed totals
  grossPay        Decimal        @map("gross_pay") @db.Decimal(12, 2)
  totalDeductions Decimal        @map("total_deductions") @db.Decimal(12, 2)
  netPay          Decimal        @map("net_pay") @db.Decimal(12, 2)
  
  currency        String         @default("ETB") @db.VarChar(3)
  status          PayrollStatus  @default(draft)
  
  // Metadata
  processedById   Int?           @map("processed_by_id")
  processedAt     DateTime?      @map("processed_at")
  paidAt          DateTime?      @map("paid_at")
  paymentMethod   String?        @map("payment_method") @db.VarChar(50)
  paymentRef      String?        @map("payment_ref") @db.VarChar(200)
  notes           String?        @db.Text
  
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  
  user            User           @relation("PayrollUser", fields: [userId], references: [id])
  processedBy     User?          @relation("PayrollProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
  @@map("payroll")
}

// ============================================
// FINANCE MODULE (Income / Expense Tracker)
// ============================================

enum FinanceType {
  income
  expense
}

enum FinanceCategory {
  // Income
  product_sale
  service_fee
  custom_order
  delivery_fee
  other_income
  // Expense
  salary_payment
  material_purchase
  rent
  utilities
  equipment
  transport
  marketing
  maintenance
  tax_payment
  other_expense
}

model FinanceTransaction {
  id              Int              @id @default(autoincrement())
  type            FinanceType
  category        FinanceCategory
  
  amount          Decimal          @db.Decimal(15, 2)
  currency        String           @default("ETB") @db.VarChar(3)
  
  // Reference
  title           String           @db.VarChar(300)
  description     String?          @db.Text
  referenceId     String?          @map("reference_id") @db.VarChar(100)
  referenceType   String?          @map("reference_type") @db.VarChar(50)  // "order", "payroll", "stock_purchase", etc.
  
  // Payment info
  paymentMethod   String?          @map("payment_method") @db.VarChar(50)
  paymentRef      String?          @map("payment_ref") @db.VarChar(200)
  
  // Date of transaction (can differ from createdAt)
  transactionDate DateTime         @map("transaction_date")
  
  // Attachments (receipt photo URLs)
  attachments     Json?            @db.Json
  
  createdById     Int?             @map("created_by_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  
  createdBy       User?            @relation("FinanceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  
  @@index([type])
  @@index([category])
  @@index([transactionDate])
  @@index([createdById])
  @@map("finance_transactions")
}
