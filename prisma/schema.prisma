  user        User   @relation("PointLedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  awardedBy   User?  @relation("PointLedgerAwardedBy", fields: [awardedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("point_ledger")
}

// ============================================
// OVERTIME LOG
// ============================================

enum OvertimeStatus {
  pending
  approved
  rejected
  paid
}

model OvertimeLog {
  id            Int            @id @default(autoincrement())
  userId        Int            @map("user_id")
  date          DateTime       @db.Date
  hoursWorked   Decimal        @map("hours_worked") @db.Decimal(5, 2)
  regularHours  Decimal        @default(8) @map("regular_hours") @db.Decimal(5, 2)
  overtimeHours Decimal        @map("overtime_hours") @db.Decimal(5, 2)
  hourlyRate    Decimal        @map("hourly_rate") @db.Decimal(10, 2)
  overtimePay   Decimal        @map("overtime_pay") @db.Decimal(10, 2)
  status        OvertimeStatus @default(pending)
  approvedById  Int?           @map("approved_by_id")
  approvedAt    DateTime?      @map("approved_at")
  note          String?        @db.Text
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user          User   @relation("OvertimeUser", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy    User?  @relation("OvertimeApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([date])
  @@index([status])
  @@map("overtime_logs")
}

// ============================================
// SALES ACTIVITY REPORT (with evidence)
// ============================================

enum SalesActivityType {
  tiktok_post
  instagram_post
  facebook_post
  customer_visit
  phone_call
  whatsapp_message
  other
}

enum SalesReportStatus {
  submitted
  reviewed
  approved
  rejected
}

model SalesActivityReport {
  id           Int                @id @default(autoincrement())
  userId       Int                @map("user_id")
  reportDate   DateTime           @map("report_date") @db.Date
  activityType SalesActivityType  @map("activity_type")
  title        String             @db.VarChar(255)
  description  String?            @db.Text
  evidenceUrl  String?            @map("evidence_url") @db.VarChar(1000)
  platform     String?            @db.VarChar(100)
  reach        Int?
  leads        Int?               @default(0)
  conversions  Int?               @default(0)
  status       SalesReportStatus  @default(submitted)
  reviewedById Int?               @map("reviewed_by_id")
  reviewedAt   DateTime?          @map("reviewed_at")
  reviewNote   String?            @map("review_note") @db.Text
  pointsAwarded Int?              @default(0) @map("points_awarded")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  user         User    @relation("SalesReportUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy   User?   @relation("SalesReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

